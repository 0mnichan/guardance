# Guardance environment variables
# Copy this file to .env and edit before running docker compose up

# Neo4j password (used by both the neo4j service and guardance)
NEO4J_PASSWORD=changeme

# Comma-separated API keys for the Guardance web API.
# Leave empty to disable authentication (development only).
GUARDANCE_API_KEYS=

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
